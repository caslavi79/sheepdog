VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional — enables the public /pay/:token page and "Copy Pay Link" admin action.
# Leave unset until Stripe account is live; pages gracefully degrade to a
# "payments unavailable" fallback. Set BOTH this AND STRIPE_SECRET_KEY (Supabase
# secret) together — partial configuration causes split-brain UX.
VITE_STRIPE_PUBLISHABLE_KEY=
